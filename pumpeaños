<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Feliz Cumpleaños Saul</title>

<style>
    body {
        margin: 0;
        font-family: 'Arial', sans-serif;
        background: linear-gradient(135deg, #c40000, #ffffff);
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        overflow: hidden;
    }

    .container {
        z-index: 2;
    }

    h1 {
        color: white;
        font-size: 2.2rem;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    }

    button {
        margin-top: 20px;
        padding: 15px 25px;
        font-size: 1.2rem;
        border: none;
        border-radius: 10px;
        background: #ff0000;
        color: white;
        cursor: pointer;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        transition: 0.3s;
    }

    button:hover {
        transform: scale(1.1);
        background: #b30000;
    }

    .gif {
        position: absolute;
        width: 80px;
        animation: float 6s infinite ease-in-out;
    }

    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-50px); }
        100% { transform: translateY(0px); }
    }

    @keyframes moveAround {
        0% { top: 10%; left: 10%; }
        25% { top: 80%; left: 20%; }
        50% { top: 50%; left: 80%; }
        75% { top: 20%; left: 60%; }
        100% { top: 10%; left: 10%; }
    }

    .moving {
        animation: moveAround 10s infinite linear, float 3s infinite ease-in-out;
    }

    @media (max-width: 600px) {
        h1 {
            font-size: 1.6rem;
        }

        button {
            font-size: 1rem;
        }

        .gif {
            width: 60px;
        }
    }
</style>
</head>

<body>

<div class="container">
    <h1>¡Feliz Cumpleaños Saul! 🎉<br>22 años... ¡WOW!</h1>
    <button onclick="mostrarSorpresa()">¡Pícale para tu sorpresa!</button>
</div>

<script>
function mostrarSorpresa() {

    const gifs = [
        "https://media.giphy.com/media/l0MYt5jPR6QX5pnqM/giphy.gif", // carro
        "https://media.giphy.com/media/NOalcASHiOGvC/giphy.gif", // kirby
        "https://media.giphy.com/media/GRSnxyhJnPsaQy9YLn/giphy.gif", // goku
        "https://media.giphy.com/media/3o7TKtnuHOHHUjR38Y/giphy.gif", // spiderman
        "https://media.giphy.com/media/12XDYvMJNcmLgQ/giphy.gif" // mario
    ];

    for (let i = 0; i < 15; i++) {
        let img = document.createElement("img");
        img.src = gifs[Math.floor(Math.random() * gifs.length)];
        img.classList.add("gif", "moving");

        img.style.top = Math.random() * 100 + "%";
        img.style.left = Math.random() * 100 + "%";

        document.body.appendChild(img);
    }
}
</script>

</body>
</html>
